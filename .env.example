DATABASE_URL="file:./prisma/dev.db"

# Shared public demo mode:
# keeps ALBA in empty state and disables attachment uploads.
NEXT_PUBLIC_ALBA_PUBLIC_DEMO="false"
NEXT_PUBLIC_ALBA_BLANK_DEMO="true"

# Optional: enable the official O*NET live bridge in Simulation.
# ESCO live works without credentials through the official public API.
ONET_USERNAME=""
ONET_PASSWORD=""
