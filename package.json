{
  "name": "alba-ikigai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start",
    "start:lan": "next start --hostname 0.0.0.0 --port 3000",
    "alba": "node scripts/alba-control.mjs up --open",
    "alba:up": "node scripts/alba-control.mjs up",
    "alba:open": "node scripts/alba-control.mjs open --open",
    "alba:status": "node scripts/alba-control.mjs status",
    "alba:down": "node scripts/alba-control.mjs down",
    "launcher:build": "node scripts/build-mac-launchers.mjs",
    "stable": "node scripts/start-stable.mjs",
    "stable:lan": "node scripts/start-stable.mjs --lan",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint .",
    "typecheck": "node scripts/typecheck.mjs",
    "prisma:generate": "DATABASE_URL=\"file:$PWD/prisma/dev.db\" prisma generate",
    "db:push": "DATABASE_URL=\"file:$PWD/prisma/dev.db\" node scripts/db-push.mjs",
    "db:seed": "DATABASE_URL=\"file:$PWD/prisma/dev.db\" prisma db seed",
    "db:init": "DATABASE_URL=\"file:$PWD/prisma/dev.db\" prisma generate && DATABASE_URL=\"file:$PWD/prisma/dev.db\" node scripts/db-push.mjs && DATABASE_URL=\"file:$PWD/prisma/dev.db\" prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "lucide-react": "^0.525.0",
    "next": "15.5.18",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.29.0",
    "eslint-config-next": "15.5.18",
    "postcss": "^8.4.49",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
